{
  "appId": "com.example.icloud-browser",
  "productName": "iCloud Browser",
  "asar": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist",
    "dist-electron",
    "node_modules",
    "package.json",
    "native-thumbnail/build/Release/macos_thumbnail.node"
  ],
  "asarUnpack": [
    "**/*.{node,dll,dylib,so}",
    "node_modules/sharp/**/*",
    "node_modules/@img/**/*",
    "native-thumbnail/build/Release/macos_thumbnail.node"
  ],
  "mac": {
    "category": "public.app-category.photography",
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "win": {
    "target": "nsis"
  },
  "linux": {
    "target": "AppImage"
  }
}
